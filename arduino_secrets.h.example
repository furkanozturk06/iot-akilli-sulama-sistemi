#ifndef ARDUINO_SECRETS_H
#define ARDUINO_SECRETS_H

// ORNEK SABLON: Bu dosyayi "arduino_secrets.h" olarak kopyalayin ve
// asagidaki placeholder degerleri kendi gercek bilgilerinizle degistirin.
// arduino_secrets.h dosyasi .gitignore ile versiyon kontrolu disinda tutulur.

// Blynk cihaz auth token'i (Blynk konsolundan alin)
#define SECRET_BLYNK_AUTH "YOUR_BLYNK_AUTH_TOKEN_HERE"

// WiFi kimlik bilgileri
#define SECRET_WIFI_SSID "YOUR_WIFI_SSID_HERE"
#define SECRET_WIFI_PASS "YOUR_WIFI_PASSWORD_HERE"

// Google Apps Script dagitim URL'si
#define SECRET_SHEET_URL "https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID_HERE/exec"

#endif // ARDUINO_SECRETS_H
